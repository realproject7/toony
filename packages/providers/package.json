{
  "name": "@toony/providers",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ./scripts/copy-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node ./scripts/copy-assets.mjs && node ../../scripts/run-tests.mjs dist"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "6.0.3"
  }
}
